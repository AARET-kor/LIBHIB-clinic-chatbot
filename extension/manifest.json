{
  "manifest_version": 3,
  "name": "TikiDoc Shadow AI",
  "version": "2.0.0",
  "description": "해외 환자 상담을 AI로 즉시 해결 — 8개국어 답변 자동 생성 · TikiDoc AI 다국어 상담 솔루션",
  "permissions": [
    "sidePanel",
    "storage",
    "clipboardRead",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "TikiDoc Shadow AI 열기 (Alt+C)"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+C",
        "mac":     "Alt+C"
      },
      "description": "TikiDoc Shadow AI 사이드패널 열기/닫기"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
